<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Guitare Custom</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GUITARE_CUSTOM_WEB.styles.css" asp-append-version="true" />
</head>
<body>

    @using Microsoft.AspNetCore.Http
    @{
        var Role = Context.Session.GetInt32("Role");
    }

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">

                <a class="navbar-brand" asp-page="/Index">Guitare Custom</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-between" id="navbarContent">

                    <ul class="navbar-nav">

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Index">Accueil</a>
                        </li>

                        @if (Role != null)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Configuration/Index">Mes configurations</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-page="/Commandes/Index">Mes Commandes</a>
                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav">

                        @if (Role == null)
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary" asp-page="/Auth/Login">Connexion</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-danger" asp-page="/Auth/Logout">Déconnexion</a>
                            </li>
                        }

                    </ul>

                </div>

            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Guitare Custom
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>